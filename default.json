{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
"extends": [
    "config:best-practices",
    "security:openssf-scorecard",
    ":semanticCommits"
  ],
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "pin",
  "automerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Fix: Update _version ARGs, LETs and ENVs in Earthfile",
      "fileMatch": ["(^|/)Earthfile$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+?)(?:\\s+depName=(?<depName>[^\\s]+))?\\s+packageName=(?<packageName>\\S+)(?:\\s+versioning=(?<versioning>[a-z-]+?))?\\n[ \\t]*(?:ENV|ARG|LET)\\s+[^\\n=]+?(?:_VERSION|_version)=(?<currentValue>[^\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ]
    }
  ]
}
